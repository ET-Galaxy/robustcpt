result <- long_data %>%
group_by(snr) %>%
summarise(meanT = mean(stoppingT), sdT=sd(stoppingT))
result$meanT<-result$meanT-600
mod1<-lm(meanT~I(snr^(-2))+0, data=result[result$snr<=0.4,], weights = 1/sdT)
