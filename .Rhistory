scale_fill_manual(values = region_colors) +
scale_x_continuous(breaks = seq(0.1, 1.2, by = 0.1)) +
scale_y_discrete(breaks = seq(500, 3000, by = 500)) +
labs(
x = expression(kappa),
y = "n",
fill = NULL
) +
theme_minimal() +
theme(
legend.position = "top"
)
