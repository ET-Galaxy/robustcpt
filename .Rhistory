# Define the range for the x-axis
x <- seq(-5, 5, length.out = 1000)
# 1. T-distribution (df = 2.1)
y_t <- dt(x, df = 2.1)
# 2. Laplace distribution (Location = 0, Scale = 1)
# Formula: f(x) = (1/(2*scale)) * exp(-abs(x-location)/scale)
y_laplace <- (1/2) * exp(-abs(x))
# Plot the T-distribution
plot(x, y_t, type = "l", col = "blue", lwd = 2,
main = "PDF: T-Distribution (df=2.1) vs. Laplace",
xlab = "x", ylab = "Density", ylim = c(0, 0.5))
# Add the Laplace distribution
lines(x, y_laplace, col = "red", lwd = 2, lty = 2)
# Add a legend
legend("topright", legend = c("T (df=2.1)", "Laplace"),
col = c("blue", "red"), lwd = 2, lty = c(1, 2))
